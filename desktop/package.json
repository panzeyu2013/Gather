{
  "name": "gather",
  "private": true,
  "version": "3.0.0",
  "license": "MIT",
  "description": "Capture One photo organization — similarity grouping and face keywording",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build && tsc -p tsconfig.main.json",
    "electron": "electron .",
    "typecheck": "tsc -p tsconfig.main.json --noEmit && tsc -p tsconfig.renderer.json --noEmit",
    "lint": "eslint src/",
    "test": "vitest run",
    "test:watch": "vitest",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:win": "npm run build && electron-builder --win"
  },
  "dependencies": {
    "@gather/shared": "*",
    "@tanstack/react-query": "^5.0.0",
    "better-sqlite3": "^11.0.0",
    "fast-xml-parser": "^4.0.0",
    "onnxruntime-node": "^1.27.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-router-dom": "^6.0.0",
    "sharp": "^0.33.0",
    "zustand": "^4.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@testing-library/jest-dom": "^6.0.0",
    "@testing-library/react": "^14.0.0",
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^26.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^8.61.1",
    "@typescript-eslint/parser": "^8.61.1",
    "@vitejs/plugin-react": "^4.0.0",
    "electron": "42.4.1",
    "electron-builder": "^26.15.3",
    "eslint": "^10.5.0",
    "globals": "^17.6.0",
    "jsdom": "^24.0.0",
    "prettier": "^3.0.0",
    "typescript": "^6.0.3",
    "vite": "^5.0.0",
    "vitest": "^1.0.0"
  }
}
