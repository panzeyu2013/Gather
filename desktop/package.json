{
  "name": "gather",
  "private": true,
  "version": "3.0.0",
  "license": "MIT",
  "description": "Capture One photo organization — similarity grouping and face keywording",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "concurrently -n main,renderer,electron -c blue,green,yellow \"npm run dev:main\" \"npm run dev:renderer\" \"wait-on tcp:5173 && npm run dev:electron\"",
    "dev:main": "tsc -p tsconfig.main.json --watch",
    "dev:renderer": "webpack serve --config webpack.renderer.config.js",
    "dev:electron": "electron .",
    "build": "npm run build:main && npm run build:renderer",
    "build:main": "tsc -p tsconfig.main.json",
    "build:renderer": "webpack --config webpack.renderer.config.js --mode production",
    "typecheck": "tsc -p tsconfig.main.json --noEmit && tsc -p tsconfig.renderer.json --noEmit",
    "test": "jest",
    "lint": "eslint src/",
    "dist:mac": "npm run bundle-python && npm run build && electron-builder --mac",
    "dist:win": "npm run build && electron-builder --win",
    "postinstall": "electron-builder install-app-deps",
    "bundle-python": "bash ../scripts/bundle-python.sh"
  },
  "dependencies": {
    "@gather/shared": "*",
    "@msgpack/msgpack": "^3.1.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^26.0.0",
    "@typescript-eslint/eslint-plugin": "^8.61.1",
    "@typescript-eslint/parser": "^8.61.1",
    "concurrently": "^10.0.3",
    "css-loader": "^6.10.0",
    "electron": "42.4.1",
    "electron-builder": "^26.15.3",
    "eslint": "^10.5.0",
    "globals": "^17.6.0",
    "html-webpack-plugin": "^5.6.0",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "style-loader": "^3.3.4",
    "ts-jest": "^29.4.11",
    "ts-loader": "^9.5.1",
    "typescript": "^6.0.3",
    "wait-on": "^9.0.10",
    "webpack": "^5.90.0",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^5.0.0"
  }
}
